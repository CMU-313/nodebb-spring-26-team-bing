<div class="forward-post-modal d-flex">
	<div class="card shadow">
		<h5 class="card-header">Forward Post</h5>
		<div class="card-body">
			<p>Search for a topic title to forward to</p>
			<p>
				<div class="input-group">
					<input class="form-control topic-search-input" type="text" placeholder="Search">
					<span class="input-group-text"><i class="fa fa-search"></i></span>
				</div>

				<div class="quick-search-container dropdown-menu d-block p-2 hidden">
					<div class="text-center loading-indicator"><i class="fa fa-spinner fa-spin"></i></div>
					<div class="quick-search-results-container"></div>
				</div>
			</p>
		</div>
		<div class="card-footer text-end">
			<button class="btn btn-link btn-sm" id="forward_post_cancel">[[global:buttons.close]]</button>
		</div>
	</div>
</div>
